# Configuracion ARCA Facturador
APP_NAME=ARCA Facturador
APP_VERSION=1.0.0
APP_DEBUG=false

# Base de datos
DB_PATH=data/arca_facturador.db
DB_WAL_MODE=true

# ARCA WSAA y WSFEv1
ARCA_HOMO=false
ARCA_CUIT=20345678901
ARCA_PUNTO_VENTA=1
ARCA_CERT_FILE=certs/certificado.crt
ARCA_KEY_FILE=certs/clave.key
ARCA_CERT_PIN=

# Seguridad
ENCRYPTION_SALT=arcafacturador2024_salt
LOG_LEVEL=INFO
LOG_RETENTION=30
LOG_ROTATION=10MB

# Directorios
CERT_DIR=certs
DATA_DIR=data
LOG_DIR=logs
TEMP_DIR=temp

# Reportes
REPORT_LOGO=resources/logo.png
REPORT_FOOTER=Gracias por su compra

# API interna
INTERNAL_API_HOST=127.0.0.1
INTERNAL_API_PORT=8742
INTERNAL_API_ENABLED=false

# Actualizaciones
UPDATE_CHECK_INTERVAL=86400
UPDATE_REPO_URL=https://api.github.com/repos/user/arca-facturador/releases/latest
